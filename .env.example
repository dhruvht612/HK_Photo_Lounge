# Mock API (default) — leave VITE_USE_SUPABASE=false
VITE_USE_SUPABASE=false
VITE_API_URL=

# Supabase (when VITE_USE_SUPABASE=true)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Legacy name also supported:
# VITE_SUPABASE_ANON_KEY=

# Clerk (client portal auth — optional; use .env.local for local dev)
VITE_CLERK_PUBLISHABLE_KEY=
